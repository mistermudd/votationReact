# Copia questo file in .env e compila i valori
# cp .env.example .env

# ───── Credenziali ruoli ─────
ADMIN_USER=admin
ADMIN_PIN=changeme

GESTIONE_USER=regia
GESTIONE_PIN=changeme

REGIA_USER=giudice
REGIA_PIN=changeme

# ───── Database ─────
# Percorso del file SQLite. Default: ./votation.db nella root.
# Su Render impostare: /var/data/votation.db
DB_PATH=

# ───── Server ─────
PORT=3000

# ───── Backup automatico su GitHub Gist ─────
# Crea un Secret Gist su https://gist.github.com con un file "votation-backup.json"
# Crea un Personal Access Token con scope "gist" su https://github.com/settings/tokens
GITHUB_BACKUP_TOKEN=
GITHUB_BACKUP_GIST_ID=
